# Shared fallback key (optional if you set tool-specific keys below)
NVAPI_KEY=your_default_api_key_here

# Chat/StepFun (server-side key for Vercel and local proxy)
CHAT_API_KEY=your_chat_api_key_here
CHAT_API_BASE_URL=https://integrate.api.nvidia.com
CHAT_API_PATH=/v1/chat/completions
CHAT_MODEL=stepfun-ai/step-3.5-flash

# Image/Stable Diffusion (server-side key for Vercel and local proxy)
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE_URL=https://ai.api.nvidia.com
IMAGE_API_PATH=/v1/genai/stabilityai/stable-diffusion-3-medium

# Optional browser fallback key for image generation only (not recommended for production)
# VITE_IMAGE_API_KEY=optional_browser_fallback_key
